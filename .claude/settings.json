{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ruff check src/ 1>&2 || exit 2"
          },
          {
            "type": "command",
            "command": "python scripts/check_structure.py 1>&2 || exit 2"
          }
        ]
      }
    ]
  }
}
